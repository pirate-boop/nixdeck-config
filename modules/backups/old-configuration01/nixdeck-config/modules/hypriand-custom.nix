#$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$#
#****************************************************************#
# HYPRLAND SYSTEM MODULE
# Системные настройки Hyprland — polkit, portal, переменные
#****************************************************************#
{ config, pkgs, lib, inputs, ... }:

{
  #****************************************************************#
  # |============================================================| #
  # | HYPRLAND CORE                                              | #
  # |============================================================| #
  #****************************************************************#
  programs.hyprland = {
    enable = true;
    withUWSM = true; # Правильный запуск через UWSM (рекомендован Hyprland)
    xwayland.enable = true;
  };

  #****************************************************************#
  # |============================================================| #
  # | XDG PORTAL (нужен для скриншотов, шеринга экрана)         | #
  # |============================================================| #
  #****************************************************************#
  xdg.portal = {
    enable = true;
    extraPortals = [ pkgs.xdg-desktop-portal-gtk ];
  };

  #****************************************************************#
  # |============================================================| #
  # | ELECTRON / WAYLAND ПЕРЕМЕННЫЕ                              | #
  # |============================================================| #
  #****************************************************************#
  environment.sessionVariables = {
    NIXOS_OZONE_WL     = "1";   # Electron на Wayland
    XDG_SESSION_TYPE   = "wayland";
    XDG_CURRENT_DESKTOP = "Hyprland";
    MOZ_ENABLE_WAYLAND = "1";   # Firefox на Wayland
    QT_QPA_PLATFORM    = "wayland";
    GDK_BACKEND        = "wayland,x11";
    SDL_VIDEODRIVER    = "wayland";
    CLUTTER_BACKEND    = "wayland";
  };

  #****************************************************************#
  # |============================================================| #
  # | POLKIT (нужен для авторизации привилегий)                  | #
  # |============================================================| #
  #****************************************************************#
  security.polkit.enable = true;
  systemd.user.services.polkit-gnome-authentication-agent-1 = {
    description = "polkit-gnome-authentication-agent-1";
    wantedBy = [ "graphical-session.target" ];
    wants = [ "graphical-session.target" ];
    after = [ "graphical-session.target" ];
    serviceConfig = {
      Type = "simple";
      ExecStart = "${pkgs.polkit_gnome}/libexec/polkit-gnome-authentication-agent-1";
      Restart = "on-failure";
      RestartSec = 1;
    };
  };

  #****************************************************************#
  # |============================================================| #
  # | ДОПОЛНИТЕЛЬНЫЕ ПАКЕТЫ ДЛЯ HYPRLAND                        | #
  # |============================================================| #
  #****************************************************************#
  environment.systemPackages = with pkgs; [
    hyprpaper      # Обои
    hyprlock       # Экран блокировки
    hypridle       # Демон idle
    hyprpicker     # Пипетка цвета
    hyprsunset     # Ночной режим
    cliphist       # История буфера обмена
    wl-clipboard   # Буфер обмена
    grim           # Скриншоты
    slurp          # Выделение области
    swappy         # Аннотации
    playerctl      # Медиа контроль
    brightnessctl  # Яркость
    libnotify      # Уведомления
    mako           # Демон уведомлений
    rofi-wayland   # Лаунчер
    gnome-keyring  # Хранилище ключей
  ];
}
#****************************************************************#
