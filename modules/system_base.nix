#$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$#

  #****************************************************************#
{ config, pkgs, lib, inputs, ... }:
  #****************************************************************#

{
  #****************************************************************#
  # |============================================================| #
  # |NETWORKING                                                  | #
  # |============================================================| #
  #****************************************************************#
  networking.hostName = "NIXDECK";
  #****************************************************************#
  networking.networkmanager.enable = true;
  #****************************************************************#
  networking.networkmanager.wifi.powersave = false;
  #****************************************************************#
  networking.hosts = { "198.18.4.40" = [ "steamdeckrepo.com" ]; };
  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#
  networking.networkmanager.settings = {
    connectivity.enabled = false; # Отключаем проверку коннективности (чтобы не ебало мозги в РФ) и IPv6
    connection."ipv6.method" = "ignore";
  };
  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#

  #****************************************************************#
  services.resolved.enable = true; #  DNS и сетевой стек
  #****************************************************************#
  networking.firewall.enable = false;
  #****************************************************************#
  # |============================================================| #
  # |LOCALIZATION                                                | #
  # |============================================================| #
  #****************************************************************#
  time.timeZone = "Europe/Moscow";
  #****************************************************************#
  i18n.defaultLocale = "en_US.UTF-8";
  #****************************************************************#

  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#
  i18n.extraLocaleSettings = {
    LC_ADDRESS        = "ru_RU.UTF-8"; # Формат адресов
    LC_IDENTIFICATION = "ru_RU.UTF-8"; # Специфические данные региона
    LC_MEASUREMENT    = "ru_RU.UTF-8"; # Метрическая система (кг, см)
    LC_MONETARY       = "ru_RU.UTF-8"; # Валюта (рубли)
    LC_NAME           = "ru_RU.UTF-8"; # Формат имен
    LC_NUMERIC        = "ru_RU.UTF-8"; # Формат чисел (разделители)
    LC_PAPER          = "ru_RU.UTF-8"; # Формат бумаги (A4 вместо Letter)
    LC_TELEPHONE      = "ru_RU.UTF-8"; # Формат номеров телефона
    LC_TIME           = "ru_RU.UTF-8"; # Формат времени и даты (24 часа)
  };
  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#

  #****************************************************************#
  services.xserver.xkb = { layout = "us"; variant = ""; };
  #****************************************************************#
  # |============================================================| #
  # |SYSTEM CORE & ENVIRONMENT                                   | #
  # |============================================================| #
  #****************************************************************#
  nixpkgs.config.allowUnfree = true;
  #****************************************************************#
  nix.settings.experimental-features = [ "nix-command" "flakes" ];
  #****************************************************************#
  nixpkgs.overlays = [ inputs.nur.overlays.default ];
  #****************************************************************#
  # |============================================================| #
  # |AUDIO & GRAPHICS                                            | #
  # |============================================================| #
  #****************************************************************#
  # Jovian управляет pipewire через enableSoundSupport автоматически
  # Мы только переопределяем wireplumber на jupiter-версию и включаем jack
  #****************************************************************#
  services.pipewire.wireplumber.package = lib.mkForce pkgs.wireplumber-jupiter;
  #****************************************************************#
  security.rtkit.enable = true;
  #****************************************************************#
  services.pipewire.jack.enable = true;
  #****************************************************************#
  # |============================================================| #
  # |SDDM и Wayland база                                         | #
  # |============================================================| #
  #****************************************************************#
  services.displayManager.sddm.wayland.enable = true;
  #****************************************************************#
  # autoStart в jovian управляет сессией — autoLogin не нужен
  #****************************************************************#
  # |============================================================| #
  # |                           NIRI                             | #
  # |============================================================| #
  #****************************************************************#

  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#
  #****************************************************************#
  programs.niri.enable = true;
  #****************************************************************#
  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#

  #****************************************************************#
  # |============================================================| #
  # |                         HYPRLAND (РЕЗЕРВ)                  | #
  # |============================================================| #
  #****************************************************************#

  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#
  #****************************************************************#
  # programs.hyprland.enable = true;
  #****************************************************************#
  # environment.sessionVariables.NIXOS_OZONE_WL = "1";
  #****************************************************************#
  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#

  #****************************************************************#
  # |============================================================| #
  # |                     ADB ANDROID TOOLS                      | #
  # |============================================================| #
  #****************************************************************#

  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#

  programs.adb.enable = true;

  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#

  #****************************************************************#
  # |============================================================| #
  # |                           STEAM                            | #
  # |============================================================| #
  #****************************************************************#

  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#
  programs.steam = {
    enable = true;
    extest.enable = true;
  };
  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#

  #****************************************************************#
  # |============================================================| #
  # |SHELL CONFIGURATION (ZSH)                                   | #
  # |============================================================| #
  #****************************************************************#

  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#
  programs.zsh = {
    enable = true;
    enableCompletion = true;
    autosuggestions.enable = true;
    syntaxHighlighting.enable = true;
    ohMyZsh = { enable = true; theme = "robbyrussell"; };
  };
  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#

  #****************************************************************#
  # |============================================================| #
  # |(QEMU/KVM) Virt-manager virtualisation                      | #
  # |============================================================| #
  #****************************************************************#
  virtualisation.libvirtd.enable = true; # Включаем виртуализацию для Virt-manager (QEMU/KVM)
  #****************************************************************#
  # |============================================================| #
  # |INPUT & SEAT                                                | #
  # |============================================================| #
  #****************************************************************#
  services.seatd.enable = true;
  #****************************************************************#
  services.inputplumber.enable = true;
  #****************************************************************#
  hardware.steam-hardware.enable = true;
  #****************************************************************#
  services.acpid.enable = true;
  #****************************************************************#
  # |============================================================| #
  # |USER ACCOUNT                                                | #
  # |============================================================| #
  #****************************************************************#

  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#
  users.users.decky = {
    isNormalUser = true;
    description  = "Juicy Pirate";
    linger       = true;
    shell        = pkgs.zsh;
    extraGroups  = [
      "networkmanager"
      "wheel"
      "libvirtd"
      "input"
      "video"
      "render"
      "seat"
      "audio"
      "gamemode"
      "adbusers"
      "users"
    ];
  };
  #>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>#

  #****************************************************************#
  # |============================================================| #
  # |SYSTEM.STATE_VERSION                                        | #
  # |============================================================| #
  #****************************************************************#
  system.stateVersion = "25.11";
}
  #****************************************************************#

#$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$#
