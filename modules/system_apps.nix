#$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$#
  #****************************************************************#
{ config, pkgs, inputs, ... }:
  #****************************************************************#

let
  #****************************************************************#
  # |============================================================| #
  # |DECKY-DEPS                                                  | #
  # |============================================================| #
  #****************************************************************#
  decky-deps = with pkgs; [
    ffmpeg
    bc
    jq
    curl
    unzip
    nodejs
    coreutils
    ryzenadj
    pulseaudio
  ];

  #****************************************************************#
  # |============================================================| #
  # |TERMINAL-APPS (все популярные терминалы — выбери лучший)    | #
  # |============================================================| #
  #****************************************************************#
  terminal-apps = with pkgs; [
    wget
    git
    htop
    fastfetch
    mission-center
    # --- Терминалы ---
    vscodium
    ghostty      # GPU-ускоренный, быстрый, современный
    alacritty    # GPU-ускоренный, минималистичный
    kitty        # GPU-ускоренный, вкладки, графика
    wezterm      # Lua конфиг, вкладки, мощный
    foot         # Лёгкий Wayland-нативный
    tilix        # GTK, вкладки, сплиты
    terminator   # Вкладки, сплиты, профили
  ];

  #****************************************************************#
  # |============================================================| #
  # |BROWSER-APPS (все популярные браузеры — выбери лучший)      | #
  # |============================================================| #
  #****************************************************************#
  browser-apps = with pkgs; [
    firefox          # Лисица, открытый
    chromium         # Хром без Google
    brave            # Chromium с блокировкой рекламы
    vivaldi          # Chromium с кучей фич
    tor-browser      # Анонимность
  ];

  #****************************************************************#
  # |============================================================| #
  # |SOCIAL-APPS                                                 | #
  # |============================================================| #
  #****************************************************************#
  social-apps = with pkgs; [
    ayugram-desktop
    vesktop
    element-desktop
  ];

  #****************************************************************#
  # |============================================================| #
  # |MEDIA-APPS                                                  | #
  # |============================================================| #
  #****************************************************************#
  media-apps = with pkgs; [
    pear-desktop
    vlc
    loupe
  ];

  #****************************************************************#
  # |============================================================| #
  # |KDE-TOOLS                                                   | #
  # |============================================================| #
  #****************************************************************#
  kde-tools = with pkgs; [
    kdePackages.dolphin
    kdePackages.kate
    kdePackages.ark
  ];

  #****************************************************************#
  # |============================================================| #
  # |GAMING-APPS                                                 | #
  # |============================================================| #
  #****************************************************************#
  gaming-apps = with pkgs; [
    protonplus
    lutris
    heroic
  ];

  #****************************************************************#
  # |============================================================| #
  # |VIRT-TOOLS                                                  | #
  # |============================================================| #
  #****************************************************************#
  virt-tools = with pkgs; [
    virt-manager
    qemu
    distrobox
  ];

  #****************************************************************#
  # |============================================================| #
  # |SYSTEM-TOOLS                                                | #
  # |============================================================| #
  #****************************************************************#
  system-tools = with pkgs; [
    xwayland-satellite
    android-tools
    qtscrcpy
    wvkbd
  ];

  #****************************************************************#
  # |============================================================| #
  # |SYSTEM-DE                                                   | #
  # |============================================================| #
  #****************************************************************#
  system-DE = [
    inputs.noctalia.packages.x86_64-linux.default
  ];

in

{
  #****************************************************************#
  # |============================================================| #
  # | SYSTEM PACKAGES                                            | #
  # |============================================================| #
  #****************************************************************#
  environment.systemPackages =
    decky-deps ++
    terminal-apps ++
    browser-apps ++
    social-apps ++
    media-apps ++
    kde-tools ++
    gaming-apps ++
    virt-tools ++
    system-tools ++
    system-DE;

  #****************************************************************#
  # |============================================================| #
  # | FONTS                                                      | #
  # |============================================================| #
  #****************************************************************#
  fonts.packages = with pkgs; [
    noto-fonts
    noto-fonts-cjk-sans
    noto-fonts-color-emoji
    liberation_ttf
    (nerd-fonts.fira-code)
    (nerd-fonts.jetbrains-mono)
  ];
}
  #****************************************************************#
#$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$#
